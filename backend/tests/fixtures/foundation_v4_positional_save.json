erprint":"b64565b6747711f88f4c7cd6f825ef5739879a78c9e58166d4c5dea43424dc8f","character_tensions":[{"character_id":"lady_vivienne_ashford","public_hook":"Self; mistress of Ashwick Manor."},{"character_id":"edgar_blackwood","public_hook":"Lady Ashford's long-serving solicitor and trustee."},{"character_id":"dr_celestine_moreau","public_hook":"A guest invited for her medical expertise."},{"character_id":"inspector_elena_hayes","public_hook":"A guest and retired detective known to Lady Ashford."},{"character_id":"captain_marcus_drake","public_hook":"A longtime family friend with a volatile history."},{"character_id":"chef_armand_dubois","public_hook":"Ashwick's head chef and employee."},{"character_id":"sabrina_voss","public_hook":"A guest whose past dealings with Lady Ashford were strained."},{"character_id":"zara_okonkwo","public_hook":"A financial investigator invited to review estate affairs."}],"public_opening":"The alarm has already sounded. Lady Vivienne Ashford is dead, the exits are closed, and every surviving guest carries a private version of the evening.","room_flavour":[{"room_id":"great_hall","text":"A vaulted hall of black oak, ancestral armour and rain-rattled leaded windows. Every principal room opens from it."},{"room_id":"drawing_room","text":"Low lamps warm a room of burgundy velvet, lacquered cabinets and a drinks trolley arranged with geometric precision."},{"room_id":"library","text":"Two storeys of books surround a reading table, a green-shaded writing desk and a broad stone fireplace."},{"room_id":"study","text":"A severe office containing the estate ledgers, a partner desk and a wall safe hidden behind a hunting print."},{"room_id":"dining_room","text":"A long table remains laid after dinner beneath a dim crystal chandelier. Silver and glass throw fractured reflections across the walls."},{"room_id":"kitchen","text":"Copper pans and iron ranges fill a practical room still hot from dinner service. A pantry door stands beyond the preparation table."},{"room_id":"gallery","text":"A narrow gallery of portraits and glass display cases runs along the eastern side of the house."},{"room_id":"conservatory","text":"Palms and winter roses crowd a glass room overlooking the flooded lawn. A tiled fountain burbles beneath the rain."},{"room_id":"chapel","text":"A small stone chapel adjoins the west wing, furnished with dark pews, a brass lectern and a curtained vestry alcove."}],"schema_version":1,"source":"fallback","tagline":"A death at Ashwick Manor. Eight lives are bound to one impossible night.","title":"The Ashwick Trust"}}
